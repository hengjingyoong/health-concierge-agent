# --- Secrets & credentials (judges: NO keys/passwords in code) ---
.env
.env.*
!.env.example
*.key
*.pem
*-service-account*.json
credentials*.json
secrets/
my-lab-*.json

# --- Real / private health data — keep PII out of a public repo ---
data/private/
data/*.db
*.private.*
**/real_*

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Local runtime artifacts (agents-cli / ADK) ---
.google-agents-cli/
**/.adk/

# --- OS / editor ---
.DS_Store
.idea/
.vscode/

# --- Eval artifacts (traces / grade results) ---
artifacts/

# --- Video production working files (local only) ---
capstone-recording/
