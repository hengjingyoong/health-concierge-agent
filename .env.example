# Copy to .env and fill in real values. NEVER commit .env or credential files.
# Model backend: Vertex AI via service account (see specs/20-architecture.md §2.1).
# Note: app/agent.py derives GOOGLE_CLOUD_PROJECT from the service account and
# pins GOOGLE_GENAI_USE_VERTEXAI=True / GOOGLE_CLOUD_LOCATION=global at import.

GOOGLE_APPLICATION_CREDENTIALS=[[PATH_TO_SERVICE_ACCOUNT_JSON]]

# Demo identity resolution ([[VARIABLE]] context hygiene — specs/30-security.md §6).
# Defaults are obviously-synthetic values; raw PII never exists in this repo.
DEMO_PATIENT_NAME=Alex Chen (synthetic)
DEMO_DOCTOR_NAME=Dr. Demo

# Policy engine session defaults (specs/30-security.md §4)
POLICY_ROLE=owner
POLICY_ENV=demo
